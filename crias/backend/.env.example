# ---- CRIAS environment variables ----
# Local development: copy to .env and fill in. Production: set these in the
# Vercel dashboard (Project Settings -> Environment Variables). Never commit .env.

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Database (use a MongoDB Atlas SRV string in production)
MONGODB_URI=mongodb://localhost:27017/crias

# Auth — JWT_SECRET MUST be a long random string (64+ chars) in production.
# Generate one:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-64+-character-random-secret
JWT_EXPIRY=24h
BCRYPT_ROUNDS=10

# CORS — leave unset for same-origin (Vercel). Set to your domain to restrict.
# CORS_ORIGIN=https://your-app.vercel.app

# Google OAuth (OPTIONAL — email/password works without it).
# If set, also put the same value in frontend/pages/login.html (data-client_id).
# GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# NOTE: The ML models now run in-process (backend/src/ml). There is no separate
# Python AI service, so AI_SERVICE_URL is no longer required.
