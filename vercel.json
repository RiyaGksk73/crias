{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "frontend/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/", "dest": "/frontend/pages/login.html" },
    { "src": "/(css|js)/(.*)", "dest": "/frontend/$1/$2" },
    { "src": "/pages/(.*)", "dest": "/frontend/pages/$1" },
    { "src": "/(.*\\.(html|css|js|png|jpg|jpeg|svg|ico|json|map))", "dest": "/frontend/$1" },
    { "src": "/(.*)", "dest": "/frontend/pages/login.html" }
  ]
}
